{% raw %}"use client";

import { useCallback, useEffect, useState } from "react";
import { Box, Heading, Text, Flex, Badge, VStack, HStack, IconButton } from "@chakra-ui/react";
import { InteractiveNvlWrapper } from "@neo4j-nvl/react";
import type { Node, Relationship } from "@neo4j-nvl/base";
import { X, ArrowRight, ArrowLeft } from "lucide-react";
import { NODE_COLORS, NODE_SIZES, DEFAULT_CYPHER, API_BASE } from "@/lib/config";

interface NvlNode extends Node {
  id: string;
  captions: { text: string }[];
  color: string;
  size: number;
}

interface NvlRelationship extends Relationship {
  id: string;
  from: string;
  to: string;
  captions: { text: string }[];
}

interface EntityConnection {
  name: string;
  labels: string[];
  relationship: string;
  direction: string;
}

export function ContextGraphView() {
  const [nodes, setNodes] = useState<NvlNode[]>([]);
  const [rels, setRels] = useState<NvlRelationship[]>([]);
  const [error, setError] = useState<string | null>(null);
  const [selectedNode, setSelectedNode] = useState<NvlNode | null>(null);
  const [entityDetail, setEntityDetail] = useState<Record<string, unknown> | null>(null);
  const [connections, setConnections] = useState<EntityConnection[]>([]);

  useEffect(() => {
    loadGraph();
  }, []);

  async function loadGraph() {
    try {
      const res = await fetch(`${API_BASE}/cypher`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ query: DEFAULT_CYPHER }),
      });
      const data = await res.json();
      transformData(data.results || []);
    } catch {
      setError("Unable to load graph data. Is the backend running?");
    }
  }

  function getNodeColor(labels: string[]): string {
    for (const label of labels) {
      if (NODE_COLORS[label]) return NODE_COLORS[label];
    }
    return "#6366f1";
  }

  function getNodeSize(labels: string[]): number {
    for (const label of labels) {
      if (NODE_SIZES[label]) return NODE_SIZES[label];
    }
    return 20;
  }

  function transformData(results: Record<string, unknown>[]) {
    const nodeMap = new Map<string, NvlNode>();
    const relList: NvlRelationship[] = [];

    for (const record of results) {
      for (const [, value] of Object.entries(record)) {
        if (value && typeof value === "object") {
          const v = value as Record<string, unknown>;
          // Detect nodes (have labels array)
          if (Array.isArray(v.labels)) {
            const id = String(v.elementId || v.id || v.name || Math.random());
            if (!nodeMap.has(id)) {
              nodeMap.set(id, {
                id,
                captions: [{ text: String(v.name || v.title || id) }],
                color: getNodeColor(v.labels as string[]),
                size: getNodeSize(v.labels as string[]),
              });
            }
          }
          // Detect relationships (have type and start/end)
          if (v.type && (v.startNodeElementId || v.start)) {
            relList.push({
              id: String(v.elementId || v.id || Math.random()),
              from: String(v.startNodeElementId || v.start),
              to: String(v.endNodeElementId || v.end),
              captions: [{ text: String(v.type) }],
            });
          }
        }
      }
    }

    setNodes(Array.from(nodeMap.values()));
    setRels(relList);
  }

  async function loadEntityDetail(name: string) {
    try {
      const res = await fetch(`${API_BASE}/entities/${encodeURIComponent(name)}`);
      const data = await res.json();
      setEntityDetail(data.entity || null);
      setConnections(data.connections || []);
    } catch {
      setEntityDetail(null);
      setConnections([]);
    }
  }

  const handleNodeClick = useCallback((_: unknown, node: Node) => {
    const nvlNode = node as NvlNode;
    setSelectedNode(nvlNode);
    const name = nvlNode.captions?.[0]?.text;
    if (name) loadEntityDetail(name);
  }, []);

  function closeDetail() {
    setEntityDetail(null);
    setSelectedNode(null);
    setConnections([]);
  }

  return (
    <Flex direction="column" h="100%">
      <Box px={4} py={3} borderBottom="1px solid" borderColor="gray.200" bg="white">
        <Heading size="sm">Knowledge Graph</Heading>
        <Text fontSize="xs" color="gray.500">
          {% endraw %}{{ domain.name }}{% raw %} entity relationships
        </Text>
      </Box>

      <Box flex={1} position="relative">
        {error ? (
          <Flex align="center" justify="center" h="100%">
            <Text color="gray.500">{error}</Text>
          </Flex>
        ) : nodes.length === 0 ? (
          <Flex align="center" justify="center" h="100%">
            <Text color="gray.500">Loading graph...</Text>
          </Flex>
        ) : (
          <InteractiveNvlWrapper
            nodes={nodes}
            rels={rels}
            nvlOptions={{
              allowDynamicMinZoom: true,
              layout: "force-directed",
              relationshipThreshold: 0.55,
            }}
            nvlCallbacks={{ onNodeClick: handleNodeClick }}
            style={{ width: "100%", height: "100%" }}
          />
        )}

        {/* Entity detail panel */}
        {entityDetail && (
          <Box
            position="absolute"
            right={0}
            top={0}
            bottom={0}
            w="320px"
            bg="white"
            borderLeft="1px solid"
            borderColor="gray.200"
            overflow="auto"
            p={4}
            zIndex={10}
            boxShadow="lg"
          >
            <Flex justify="space-between" align="center" mb={3}>
              <Heading size="sm">
                {selectedNode?.captions?.[0]?.text}
              </Heading>
              <IconButton
                aria-label="Close"
                size="xs"
                variant="ghost"
                onClick={closeDetail}
              >
                <X size={14} />
              </IconButton>
            </Flex>

            {/* Labels */}
            <HStack mb={3} flexWrap="wrap" gap={1}>
              {((entityDetail._labels as string[]) || []).map((label) => (
                <Badge key={label} colorPalette="blue" size="sm">
                  {label}
                </Badge>
              ))}
            </HStack>

            {/* Properties */}
            <VStack align="stretch" gap={2} mb={4}>
              {Object.entries(entityDetail)
                .filter(([k]) => k !== "_labels" && k !== "name")
                .map(([key, value]) => (
                  <Box key={key}>
                    <Text fontSize="xs" color="gray.500" fontWeight="medium">
                      {key.replace(/_/g, " ")}
                    </Text>
                    <Text fontSize="sm">{String(value ?? "—")}</Text>
                  </Box>
                ))}
            </VStack>

            {/* Connections */}
            {connections.length > 0 && (
              <>
                <Heading size="xs" mb={2}>
                  Connections ({connections.length})
                </Heading>
                <VStack align="stretch" gap={1}>
                  {connections.map((conn, i) => (
                    <HStack key={i} fontSize="xs" gap={1}>
                      {conn.direction === "outgoing" ? (
                        <ArrowRight size={10} />
                      ) : (
                        <ArrowLeft size={10} />
                      )}
                      <Badge size="sm" variant="outline" flexShrink={0}>
                        {conn.relationship}
                      </Badge>
                      <Text truncate>{conn.name}</Text>
                    </HStack>
                  ))}
                </VStack>
              </>
            )}
          </Box>
        )}
      </Box>

      {/* Color legend */}
      <Box px={4} py={2} borderTop="1px solid" borderColor="gray.200" bg="white">
        <Flex gap={3} flexWrap="wrap">
          {Object.entries(NODE_COLORS).map(([label, color]) => (
            <Flex key={label} align="center" gap={1}>
              <Box w={3} h={3} borderRadius="full" bg={color} />
              <Text fontSize="xs">{label}</Text>
            </Flex>
          ))}
        </Flex>
      </Box>
    </Flex>
  );
}
{% endraw %}
